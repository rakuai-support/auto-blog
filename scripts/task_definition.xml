    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <ExecutionTimeLimit>PT30M</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>C:\Users\utaka\rakuai\projects\1000challenge\auto-blog\scripts\run_daily.bat</Command>
      <WorkingDirectory>C:\Users\utaka\rakuai\projects\1000challenge\auto-blog</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
